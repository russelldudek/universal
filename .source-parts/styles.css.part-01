.stage-controls{margin-top:1rem}.scenario-tabs{display:flex;gap:.45rem;flex-wrap:wrap}.scenario-tabs button{background:transparent;color:#cbd5e1;border:1px solid rgba(255,255,255,.17);padding:.47rem .62rem;border-radius:.25rem;font-size:.69rem;cursor:pointer}.scenario-tabs button[aria-selected="true"]{background:#fff;color:#07101f;border-color:#fff}.scenario-tabs button:focus-visible{outline:2px solid var(--campaign-cyan);outline-offset:2px}.scenario-readout{display:grid;grid-template-columns:1fr auto;gap:1rem;margin-top:.9rem;align-items:end}.scenario-readout p{margin:0;color:#cbd5e1;font-size:.83rem}.scenario-readout strong{color:#fff}.restore-btn{border:1px solid var(--campaign-cyan);color:var(--campaign-cyan);background:transparent;padding:.52rem .65rem;border-radius:.25rem;font-weight:700;cursor:pointer;white-space:nowrap}.restore-btn:hover,.restore-btn:focus-visible{background:var(--campaign-cyan);color:#04111b;outline:none}
@keyframes spotlight{from{transform:translateX(-56%) rotate(-3deg)}to{transform:translateX(-44%) rotate(3deg)}}@keyframes flatSweep{0%,68%{transform:translateX(-130%)}85%,100%{transform:translateX(130%)}}
.section{padding:clamp(4.25rem,8vw,8rem) clamp(1rem,6vw,7rem);position:relative}.section.light{background:var(--paper-soft);color:var(--ink)}.section.white{background:#fff;color:var(--ink)}.section.dark{background:#081126}.section.gold{background:linear-gradient(135deg,#171007,#2c220f);color:#fff}.section-kicker{font-size:.68rem;text-transform:uppercase;letter-spacing:.17em;font-weight:700;color:var(--brand-blue);margin:0 0 .8rem}.dark .section-kicker,.gold .section-kicker{color:var(--campaign-cyan)}.section h2{font-family:"Cabin",sans-serif;font-size:clamp(2.2rem,4.4vw,4.7rem);line-height:.98;letter-spacing:-.04em;margin:0 0 1.2rem;max-width:18ch}.section-lede{font-size:clamp(1rem,1.4vw,1.25rem);max-width:54rem;color:var(--muted);margin:0}.dark .section-lede,.gold .section-lede{color:#cbd5e1}.moment-grid{display:grid;grid-template-columns:.8fr 1.2fr;gap:clamp(2rem,8vw,9rem);margin-top:3.5rem;align-items:start}.moment-facts{display:grid;gap:1rem}.fact{padding:1.2rem 0;border-top:1px solid var(--line)}.fact b{font-family:"Cabin",sans-serif;font-size:2.2rem;display:block;color:var(--brand-deep-blue)}.fact span{color:var(--muted);font-size:.86rem}.mandate{font-family:"Cabin",sans-serif;font-size:clamp(1.65rem,3vw,3rem);line-height:1.18;margin:0}.hypothesis-tag{display:inline-block;margin-top:1.1rem;font-size:.66rem;letter-spacing:.12em;text-transform:uppercase;color:var(--brand-blue);border:1px solid #b8c8e4;padding:.32rem .48rem;border-radius:999px}.tension-table{margin-top:3rem;border-top:1px solid rgba(255,255,255,.22)}.tension-row{display:grid;grid-template-columns:1fr auto 1fr;gap:1.2rem;align-items:center;padding:1.25rem 0;border-bottom:1px solid rgba(255,255,255,.14)}.tension-row span:nth-child(2){font-size:.63rem;letter-spacing:.15em;color:var(--campaign-cyan);text-transform:uppercase}.tension-row strong:last-child{text-align:right}.books{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:#cdd5e2;border:1px solid #cdd5e2;margin-top:3rem}.book{background:#fff;padding:1.35rem;min-height:270px;position:relative}.book:before{content:attr(data-num);display:block;font-family:"Cabin",sans-serif;font-size:3rem;color:#d9e2f2;line-height:1;margin-bottom:1.6rem}.book h3{font-family:"Cabin",sans-serif;font-size:1.25rem;margin:0 0 .55rem}.book p{font-size:.84rem;color:var(--muted);margin:0}.book ul{padding-left:1rem;color:var(--muted);font-size:.8rem}.book .book-call{position:absolute;left:1.35rem;bottom:1.2rem;font-size:.61rem;text-transform:uppercase;letter-spacing:.11em;color:var(--brand-blue);font-weight:700}.decision-band{display:grid;grid-template-columns:1.1fr .9fr;gap:3rem;align-items:center;margin-top:4rem;padding:2rem;border:1px solid #ccd6e5;background:linear-gradient(135deg,#fff,#f2f5fa)}.decision-band h3{font-family:"Cabin",sans-serif;font-size:1.65rem;margin:0}.decision-list{display:grid;grid-template-columns:repeat(2,1fr);gap:.6rem}.decision-list span{padding:.65rem;border-left:3px solid var(--brand-blue);background:#fff;font-size:.78rem;font-weight:700}.scorecard{margin-top:3rem;display:grid;grid-template-columns:repeat(6,1fr);border-top:1px solid rgba(255,255,255,.2);border-left:1px solid rgba(255,255,255,.2)}.score{padding:1.25rem .9rem;min-height:190px;border-right:1px solid rgba(255,255,255,.2);border-bottom:1px solid rgba(255,255,255,.2)}.score b{display:block;color:var(--campaign-cyan);font-family:"Cabin",sans-serif;font-size:1rem}.score p{font-size:.73rem;color:#cbd5e1;margin:.75rem 0 0}.evidence-map{margin-top:3rem;position:relative}.evidence-row{display:grid;grid-template-columns:170px 1fr 1fr;gap:1.5rem;padding:1.35rem 0;border-top:1px solid var(--line)}.evidence-row .years{font-family:"Cabin",sans-serif;color:var(--brand-blue);font-size:.85rem}.evidence-row h3{margin:0;font-family:"Cabin",sans-serif;font-size:1.18rem}.evidence-row p{margin:0;color:var(--muted);font-size:.83rem}.plan-strip{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(255,255,255,.17);border:1px solid rgba(255,255,255,.17);margin-top:3rem}.plan-phase{background:#0b1630;padding:1.4rem;min-height:250px}.plan-phase span{font-size:.62rem;letter-spacing:.12em;text-transform:uppercase;color:var(--campaign-cyan)}.plan-phase h3{font-family:"Cabin",sans-serif;font-size:1.25rem;margin:.45rem 0}.plan-phase p{font-size:.79rem;color:#cbd5e1}.objection{display:grid;grid-template-columns:.72fr 1.28fr;gap:clamp(2rem,8vw,8rem);align-items:start}.objection blockquote{font-family:"Cabin",sans-serif;font-size:clamp(1.8rem,3.6vw,3.7rem);line-height:1.05;margin:0}.objection-answer{font-size:1.05rem;color:#e3eaf5}.objection-answer strong{color:var(--campaign-cyan)}.questions{counter-reset:q;display:grid;grid-template-columns:1fr 1fr;gap:0 2rem;margin-top:3rem}.question{counter-increment:q;padding:1.05rem 0;border-top:1px solid var(--line);display:grid;grid-template-columns:2rem 1fr;gap:.6rem}.question:before{content:counter(q,decimal-leading-zero);color:var(--brand-blue);font-family:"Cabin",sans-serif;font-weight:700}.question p{margin:0;font-size:.88rem}.artifact-cta{display:grid;grid-template-columns:1.2fr .8fr;gap:3rem;align-items:center}.artifact-links{display:grid;grid-template-columns:1fr 1fr;gap:.65rem}.artifact-links a{background:#fff;color:#101827;text-decoration:none;padding:1rem;border-left:3px solid var(--campaign-cyan);font-weight:7