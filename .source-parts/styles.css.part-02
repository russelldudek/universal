00;font-size:.84rem}.artifact-links a:hover,.artifact-links a:focus-visible{background:var(--campaign-cyan);outline:none}.site-footer{padding:2rem clamp(1rem,6vw,7rem);background:#02040a;color:#8290a5;font-size:.7rem;border-top:1px solid rgba(255,255,255,.1);display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap}
/* document surfaces */
.document-body{background:#e7ebf2;color:var(--ink);min-height:100vh}.document-nav{position:sticky;top:0;z-index:20;background:#081126;color:#fff;padding:.7rem 1rem;display:flex;justify-content:space-between;align-items:center;gap:1rem}.document-nav .doc-actions{margin:0}.document-nav .btn{padding:.52rem .7rem;font-size:.7rem}.document-shell{padding:2rem 1rem 4rem}.sheet,.report-page{width:8.5in;min-height:11in;margin:0 auto 1.5rem;background:#fff;box-shadow:0 18px 50px rgba(14,24,45,.2);position:relative;overflow:visible}.sheet-inner,.report-inner{padding:.52in .56in .48in}.doc-header{display:grid;grid-template-columns:1fr auto;gap:.25in;align-items:start;border-top:5px solid var(--brand-deep-blue);padding-top:.14in;padding-bottom:.13in;border-bottom:1px solid #cdd5e2}.doc-header h1{font-family:"Cabin",sans-serif;font-size:25pt;line-height:1;margin:0;color:#0b1730;letter-spacing:-.035em}.doc-header .identity{font-family:"Cabin",sans-serif;font-size:10.5pt;font-weight:700;color:var(--brand-blue);margin-top:.05in}.doc-logo{width:1.65in;margin-left:auto}.contact-line{font-size:7.1pt;line-height:1.5;color:#49566a;margin-top:.08in;display:flex;flex-wrap:wrap;gap:0 .12in}.contact-line a{color:#304e87;text-decoration:none}.target-line{font-size:7pt;text-transform:uppercase;letter-spacing:.12em;color:#66758a;margin-top:.045in}.doc-section{margin-top:.16in}.doc-section h2{font-family:"Cabin",sans-serif;font-size:10.5pt;color:#152c58;margin:0 0 .06in;text-transform:uppercase;letter-spacing:.08em;border-bottom:1px solid #bfc9da;padding-bottom:.035in}.doc-section p{font-size:8.25pt;line-height:1.35;margin:.045in 0}.cap-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.055in .08in}.cap-grid span{font-size:7.5pt;font-weight:700;padding:.055in .07in;background:#edf2f8;border-left:2px solid var(--brand-blue)}.experience{margin-top:.1in}.experience-head{display:grid;grid-template-columns:1fr auto;gap:.15in;align-items:baseline}.experience h3{font-family:"Cabin",sans-serif;font-size:9.5pt;margin:0;color:#111827}.experience .role{font-size:7.9pt;font-weight:700;color:#3e5f98}.experience time{font-size:7pt;color:#637083;white-space:nowrap}.experience ul{margin:.03in 0 0 .14in;padding:0}.experience li{font-size:7.55pt;line-height:1.29;margin:.018in 0}.page-footer{position:absolute;left:.56in;right:.56in;bottom:.22in;border-top:1px solid #d3dae6;padding-top:.055in;display:flex;justify-content:space-between;font-size:6.5pt;color:#6a7688}.resume-columns{display:grid;grid-template-columns:1.15fr .85fr;gap:.18in}.tight-list{margin:.03in 0 0 .14in;padding:0}.tight-list li{font-size:7.4pt;line-height:1.28;margin:.02in 0}.mini-card{padding:.09in .1in;background:#f1f4f8;border-left:3px solid var(--brand-blue);margin-bottom:.07in}.mini-card h3{font-size:8.4pt;margin:0}.mini-card p{font-size:7.2pt;margin:.025in 0 0}.credentials{display:flex;flex-wrap:wrap;gap:.045in}.credentials span{font-size:6.8pt;padding:.04in .065in;background:#0e1b36;color:#fff}.cover-body{font-size:9pt;line-height:1.43;margin-top:.2in}.cover-body p{margin:.11in 0}.cover-address{font-size:8.2pt;margin-top:.17in}.signature{margin-top:.18in}.signature strong{display:block;font-family:"Cabin",sans-serif;font-size:11pt}.report-page{page-break-after:always}.report-page:last-child{page-break-after:auto}.report-title{background:linear-gradient(135deg,#051020,#172e5d);color:#fff;min-height:11in}.report-title .report-inner{min-height:11in;display:flex;flex-direction:column}.report-lockup{display:flex;align-items:center;justify-content:space-between;gap:.3in}.report-lockup img{width:1.8in}.report-label{font-size:7.5pt;text-transform:uppercase;letter-spacing:.14em;color:#b8c8df}.report-title h1{font-family:"Cabin",sans-serif;font-size:39pt;line-height:.98;letter-spacing:-.04em;max-width:6.5in;margin:1.35in 0 .25in}.report-title .deck{font-size:14pt;line-height:1.35;max-width:5.9in;color:#d7e1f0}.report-title .thesis{margin-top:auto;border-top:1px solid rgba(255,255,255,.25);padding-top:.2in;font-family:"Cabin",sans-serif;font-size:18pt;color:var(--campaign-cyan)}.report-header{display:flex;justify-content:space-between;align-items:center;border-bottom:2px solid var(--brand-deep-blue);padding-bottom:.08in;margin-bottom:.18in}.report-header h1{font-family:"Cabin",sans-serif;font-size:13pt;margin:0}.report-header img{width:1.1in}.report-section{margin-top:.22in}.report-section h2{font-family:"Cabin",sans-serif;color:#162d59;font-size:18pt;margin:0 0 .11in}.report-section h3{font-family:"Cabin",sans-serif;font-size:11.5pt;margin:.14in 0 .05in;color:#243e70}.report-section p,.report-section li{font-size:10pt;line-height:1.48}.report-section p{margin:.085in 0}.report-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:.18in}.report-grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:.14in}.report-card{border:1px solid #cfd7e4;padding:.17in;background:#f8fafc;break-inside:avoid}.report-card h3{margin:0 0 .055in}.report-card p{font-size:9pt;line-height:1.4;margin:0}.question-grid .report-card{min-height:1.25in}.callout{padding:.18in .2in;background:#0b1730;color:#fff;border-left:5px solid var(--campaign-cyan);font-size:11pt;line-height:1.42;margin:.16in 0}.source-list{font-size:8.6pt;line-height:1.45;padding-left:.18in}.phase-table{width:100%;border-collapse:collapse;margin-top:.1in}.phase-table th,.phase-table td{border:1px solid #cfd7e4;padding:.085in;vertical-align:top;font-size:8.8pt;line-height:1.38}.phase-table th{background:#172e5d;color:#fff;text-align:left;font-size:7pt;text-transform:uppercase;letter-spacing:.06em}.review-grid{display:grid;grid-template-columns:1fr 1fr;gap:.1in}.review-field{border:1px solid #bdc8d9;padding:.09in;min-height:.72in}.review-field strong{display:block;font-family:"Cabin",sans-serif;color:#1e396d;font-size:8.4pt}.review-field span{font-size:7.2pt;color:#66758a}.decision-rail{display:grid;grid-template-columns:repeat(4,1fr);gap:.06in;margin-top:.12in}.decision-rail div{padding:.11in;text-align:center;font-weight:700;font-size:8pt;border:1px solid #bac6d8}.decision-rail div:first-child{background:#daf7ff}.decision-rail div:nth-child(2){background:#fff2ce}.d